APP_NAME="Device Event Ingestion Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

# Host-side ports exposed by docker-compose. Defaults avoid clashes with
# common local services (3306 → host 3307, 6379 → host 6380). Override
# here if you want different mappings — container-internal ports are fixed.
APP_HOST_PORT=8000
DB_HOST_PORT=3307
REDIS_HOST_PORT=6380

LOG_CHANNEL=stack
LOG_STACK=single,stderr
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=device_event_ingestion_svc
DB_USERNAME=app
DB_PASSWORD=secret

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
QUEUE_CONNECTION=database
SESSION_DRIVER=array
SESSION_LIFETIME=120

# Static API key required on POST /api/v1/device-events. Required in any
# non-local environment — an unset value in production/staging causes the
# ingestion endpoint to refuse all requests with HTTP 500 (see ApiKeyAuth).
INGESTION_API_KEY=local-dev-key-change-me

# Per-device rate limit on ingestion (max requests per minute, per IMEI).
INGESTION_RATE_LIMIT_PER_MINUTE=120

# Redis dedup TTL in seconds (default: 24h).
INGESTION_DEDUP_TTL_SECONDS=86400
