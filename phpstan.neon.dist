includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 6
    paths:
        - app
        - config
        - database
        - routes
        - tests
    excludePaths:
        - vendor/*
        - storage/*
        - bootstrap/cache/*
        - .composer-cache/*
        - .composer-home/*
        - .phpunit.cache/*

    # Tests sometimes intentionally pass invalid arguments to assert exception
    # paths — keep them in scope but be a little less strict about return types
    # there. We can tighten this once the suite is stable.
    treatPhpDocTypesAsCertain: false

    # Project conventions for cross-cutting types.
    universalObjectCratesClasses:
        - Illuminate\Http\Resources\Json\JsonResource
